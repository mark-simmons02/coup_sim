{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "C/C++: g++.exe build active file",
            "type": "shell",
            "command": "C:\\msys64\\ucrt64\\bin\\g++.exe",
            "args": [
                "-fdiagnostics-color=always",
                "-g",
                "-std=c++17",
                "${workspaceFolder}/program.cpp",
                "${workspaceFolder}/src/action.cpp",
                "${workspaceFolder}/src/player.cpp",
                "${workspaceFolder}/src/public_state.cpp",
                "${workspaceFolder}/src/world.cpp",
                "-I",
                "${workspaceFolder}/lib",
                "-o",
                "${workspaceFolder}/program.exe"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": [
                "$gcc"
            ],
            "detail": "Build all sources to program.exe"
        },
        {
            "type": "cppbuild",
            "label": "C/C++: g++.exe build single file",
            "command": "C:/msys64/ucrt64/bin/g++.exe",
            "args": [
                "-fdiagnostics-color=always",
                "-g",
                "-std=c++17",
                "${file}",
                "-o",
                "${fileDirname}\\${fileBasenameNoExtension}.exe"
            ],
            "options": {
                "cwd": "C:/msys64/ucrt64/bin"
            },
            "problemMatcher": [
                "$gcc"
            ],
            "group": {
                "kind": "build",
                "isDefault": false
            },
            "detail": "Build single active file only"
        }
    ]
}